# --- Hermes (gateway mode) ----------------------------------------------------
# Model/API keys are read from the environment. Provide whichever you use.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# Optional: enable the dashboard (port 9119)
# HERMES_DASHBOARD=1

# Optional: messaging platform tokens (configure via `hermes gateway setup`)
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=

# --- GitHub CLI auth (https://cli.github.com/manual/gh_help_environment) ------
# Primary token understood by `gh`. Generate at: https://github.com/settings/tokens
GH_TOKEN=

# Optional: override the default GitHub host (for GitHub Enterprise)
# GH_HOST=github.example.com

# Optional: token for GitHub Enterprise
# GH_ENTERPRISE_TOKEN=

# Optional: editor used by `gh` for interactive commands
# GH_EDITOR=code
